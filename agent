def main():
    """Main entry point for the agent wrapper script."""
    # Parse for --paid flag before subcommand
    paid = False
    remaining_args = []
    
    for arg in sys.argv[1:]:
        if arg == "--paid":
            paid = True
        else:
            remaining_args.append(arg)
    
    if len(remaining_args) < 1:
        print("Error: No subcommand provided.", file=sys.stderr)
        print_usage()
        sys.exit(1)

    subcommand = remaining_args[0]

    if subcommand not in AGENT_MAP:
        print(f"Error: Invalid subcommand '{subcommand}'.", file=sys.stderr)
        print_usage()
        sys.exit(1)

    # Special handling for improve subcommand
    if subcommand == "improve":
        handle_improve_subcommand(paid)
        sys.exit(0)

    agent_name = AGENT_MAP[subcommand]
    workflow_type = subcommand

    # Check for cleanup opportunities
    check_cleanup()
    
    # Prompt for new or resume
    try:
        work = prompt_new_or_resume(workflow_type)
    except CancelledError:
        sys.exit(1)
    
    # Launch agent in worktree (or current directory for main branch)
    launch_agent(work, agent_name, paid)


if __name__ == "__main__":
    main()
