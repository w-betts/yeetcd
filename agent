#!/usr/bin/env python3
"""
Agent wrapper script for Mac/Linux.

Maps subcommands to agent names and launches opencode with the appropriate agent.
Does NOT pass any prompt - user enters prompt in TUI.

Usage:
    agent spec    - Launch spec agent (4-phase structured workflow)
    agent vibe    - Launch vibe agent (direct implementation workflow)
"""

import subprocess
import sys

# Map subcommands to agent names
AGENT_MAP = {
    "spec": "spec",
    "vibe": "vibe",
}


def main():
    """Main entry point for the agent wrapper script."""
    if len(sys.argv) < 2:
        print("Error: No subcommand provided.", file=sys.stderr)
        print_usage()
        sys.exit(1)

    subcommand = sys.argv[1]

    if subcommand not in AGENT_MAP:
        print(f"Error: Invalid subcommand '{subcommand}'.", file=sys.stderr)
        print_usage()
        sys.exit(1)

    agent_name = AGENT_MAP[subcommand]

    # Launch opencode with the selected agent
    # Do NOT pass any prompt - user enters it in TUI
    try:
        subprocess.run(["opencode", "--agent", agent_name], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Error: opencode exited with code {e.returncode}", file=sys.stderr)
        sys.exit(e.returncode)
    except FileNotFoundError:
        print("Error: opencode command not found. Please install opencode.", file=sys.stderr)
        sys.exit(1)


def print_usage():
    """Print usage information."""
    print("Usage: agent <subcommand>", file=sys.stderr)
    print("", file=sys.stderr)
    print("Subcommands:", file=sys.stderr)
    print("  spec   - Launch spec agent (4-phase structured workflow)", file=sys.stderr)
    print("  vibe   - Launch vibe agent (direct implementation workflow)", file=sys.stderr)
    print("", file=sys.stderr)
    print("Examples:", file=sys.stderr)
    print("  agent spec    # Start structured workflow for complex features", file=sys.stderr)
    print("  agent vibe    # Start direct workflow for rapid iteration", file=sys.stderr)


if __name__ == "__main__":
    main()
