    """Print usage information."""
    print("Usage: agent [options] <subcommand>", file=sys.stderr)
    print("", file=sys.stderr)
    print("Options:", file=sys.stderr)
    print("  --paid    Use paid model (opencode/minimax-m2.5) instead of free models", file=sys.stderr)
    print("", file=sys.stderr)
    print("Subcommands:", file=sys.stderr)
