{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "spec": {
      "mode": "primary",
      "description": "Spec agent - orchestrates phase-based workflow for complex features requiring planning and architecture",
      "prompt": "{file:./.opencode/prompts/spec.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow",
          "document": "allow"
        }
      }
    },
    "vibe": {
      "mode": "primary",
      "description": "Vibe agent - direct implementation workflow for rapid iteration and simpler tasks",
      "prompt": "{file:./.opencode/prompts/vibe.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "edit": {
          "*": "allow"
        },
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow",
          "document": "allow"
        }
      }
    },
    "fix": {
      "mode": "primary",
      "description": "Fix agent - test-driven bug fixing workflow",
      "prompt": "{file:./.opencode/prompts/fix.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "edit": {
          "*": "allow"
        },
        "task": {
          "*": "deny",
          "test-writer": "allow"
        }
      }
    },
    "document": {
      "mode": "primary",
      "description": "Document agent - orchestrates two-phase documentation workflow for keeping code docs in sync",
      "prompt": "{file:./.opencode/prompts/document.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "doc_write": "allow",
        "doc_update": "allow",
        "task": {
          "*": "deny",
          "agent-doc-writer": "allow",
          "human-doc-writer": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/planner.md}",
      "temperature": 0.2,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "temperature": 0.2,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "test-writer": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/test-writer.md}",
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "implementer": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/implementer.md}",
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "agent-doc-writer": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/agent-doc-writer.md}",
      "temperature": 0.3,
      "permission": {
        "doc_read": "allow",
        "doc_write": "allow",
        "doc_update": "allow",
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "bash": "allow",
        "edit": {
          "*": "deny"
        },
        "task": "deny"
      }
    },
    "human-doc-writer": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/human-doc-writer.md}",
      "temperature": 0.3,
      "permission": {
        "doc_read": "allow",
        "write": "allow",
        "glob": "allow",
        "edit": {
          "*": "deny"
        },
        "task": "deny"
      }
    },
    "improve": {
      "mode": "primary",
      "description": "Improve agent - analyzes recorded session problems and proposes workflow improvements",
      "prompt": "{file:./.opencode/prompts/improve.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "read": "allow",
        "glob": "allow",
        "edit": {
          "*": "allow"
        },
        "write": "allow",
        "bash": "allow"
      }
    }
  },
  "plugin": [
    "./.opencode/plugins/notification-plugin.ts",
    "./.opencode/tools/session.ts"
  ],
  "provider": {
    "opencode": {
      "models": {
        "minimax-m2.5": {
          "limit": {
            "context": 64000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
        "*": "allow"
    }
  }
}
