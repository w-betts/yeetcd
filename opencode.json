{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Build mode - orchestrates feature development through planning, testing, and implementation phases",
      "prompt": "{file:./.opencode/prompts/orchestrator.txt}",
      "temperature": 0.3,
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "test-writer": "allow",
          "implementer": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Plan mode - orchestrates feature development (same workflow as build, with restricted direct permissions)",
      "prompt": "{file:./.opencode/prompts/orchestrator.txt}",
      "temperature": 0.3,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "task": {
          "*": "deny",
          "planner": "allow",
          "test-writer": "allow",
          "implementer": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "opencode/glm-5",
      "hidden": false,
      "temperature": 0.2,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/plans/*.yaml": "allow",
          ".opencode/plans/*.json": "allow"
        },
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "find *": "allow",
          "git *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },
    "test-writer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "bash": {
          "*": "allow"
        },
        "task": "deny"
      }
    },
    "implementer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "bash": {
          "*": "allow"
        },
        "task": "deny"
      }
    }
  },
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
      "*": "ask"
    }
  }
}
