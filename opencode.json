{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "spec": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Spec agent - orchestrates phase-based workflow for complex features requiring planning and architecture",
      "prompt": "{file:./.opencode/prompts/spec.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow",
          "document": "allow"
        }
      }
    },
    "vibe": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Vibe agent - direct implementation workflow for rapid iteration and simpler tasks",
      "prompt": "{file:./.opencode/prompts/vibe.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "edit": {
          "*": "allow"
        },
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow",
          "document": "allow"
        }
      }
    },
    "document": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Document agent - orchestrates two-phase documentation workflow for keeping code docs in sync",
      "prompt": "{file:./.opencode/prompts/document.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "doc_read": "allow",
        "doc_write": "allow",
        "doc_update": "allow",
        "task": {
          "*": "deny",
          "agent-doc-writer": "allow",
          "human-doc-writer": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "opencode/glm-5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/planner.md}",
      "temperature": 0.2,
      "steps": 50,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "temperature": 0.2,
      "steps": 15,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "test-writer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/test-writer.md}",
      "temperature": 0.3,
      "steps": 25,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "implementer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/implementer.md}",
      "temperature": 0.3,
      "steps": 40,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "agent-doc-writer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/agent-doc-writer.md}",
      "temperature": 0.3,
      "steps": 50,
      "permission": {
        "doc_read": "allow",
        "doc_write": "allow",
        "doc_update": "allow",
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "bash": "allow",
        "edit": {
          "*": "deny"
        },
        "task": "deny"
      }
    },
    "human-doc-writer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/human-doc-writer.md}",
      "temperature": 0.3,
      "steps": 40,
      "permission": {
        "doc_read": "allow",
        "write": "allow",
        "glob": "allow",
        "edit": {
          "*": "deny"
        },
        "task": "deny"
      }
    }
  },
  "plugin": [
    "./.opencode/plugins/notification-plugin.ts",
    "./.opencode/plugins/permission-save-plugin.ts"
  ],
  "provider": {
    "opencode": {
      "models": {
        "glm-5": {
          "limit": {
            "context": 64000,
            "output": 16384
          }
        },
        "minimax-m2.5-free": {
          "limit": {
            "context": 64000,
            "output": 16384
          }
        },
        "kimi-k2.5": {
          "limit": {
            "context": 64000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
        "*": "ask",
        "./mvnw *": "allow",
        "rm /Users/will/projects/yeetcd/*": "allow",
        "bun *": "allow",
        "bun build *": "ask",
        "cat *": "allow",
        "file *": "allow",
        "find *": "allow",
        "git -C *": "allow",
        "git add *": "allow",
        "git branch *": "allow",
        "git commit *": "allow",
        "git diff *": "allow",
        "git fetch origin main *": "allow",
        "git log *": "allow",
        "git push *": "allow",
        "git rebase main *": "allow",
        "git status *": "allow",
        "git worktree *": "allow",
        "grep *": "allow",
        "head *": "allow",
        "ls *": "allow",
        "npm test *": "allow",
        "pwd *": "allow",
        "tail *": "allow",
        "true *": "allow",
        "wc *": "allow",
        "opencode --help *": "allow",
        "which *": "allow"
    }
  }
}
