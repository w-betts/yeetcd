{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "spec": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Spec agent - orchestrates phase-based workflow for complex features requiring planning and architecture",
      "prompt": "{file:./.opencode/prompts/spec.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow"
        }
      }
    },
    "vibe": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "description": "Vibe agent - direct implementation workflow for rapid iteration and simpler tasks",
      "prompt": "{file:./.opencode/prompts/vibe.md}",
      "temperature": 0.3,
      "permission": {
        "question": "allow",
        "edit": {
          "*": "allow"
        },
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "test-writer": "allow",
          "implementer": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "opencode/glm-5",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/planner.md}",
      "temperature": 0.2,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "hidden": false,
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "temperature": 0.2,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/specs/*.yaml": "allow"
        },
        "task": "deny"
      }
    },
    "test-writer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    },
    "implementer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "hidden": false,
      "temperature": 0.3,
      "permission": {
        "edit": {
          "*": "ask"
        },
        "task": "deny"
      }
    }
  },
  "permission": {
    "edit": {
      "*": "allow"
    }
  },
  "plugin": [".opencode/notification-plugin.ts"]
}
